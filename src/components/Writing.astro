---
// Writing — pointer to the Substack.
//
// If you later add a proper RSS/JSON fetch here to show the last 3 posts,
// replace the placeholder body below.
---

<section id="writing" class="section-anchor border-t border-neutral-200 dark:border-neutral-800">
  <div class="mx-auto max-w-content px-6 py-20 md:py-24">
    <p class="kicker mb-4">Writing</p>
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
      Impulsed Inertia
    </h2>
    <p class="mt-4 max-w-2xl text-ink-muted dark:text-neutral-400">
      Notes from the build process — what actually works, what breaks, and
      what I'm learning about shipping with AI as the primary collaborator.
    </p>

    <div class="mt-10">
      <a
        href="https://impulsedinertia.substack.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-md border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 px-6 py-4 text-sm font-medium text-ink dark:text-neutral-100 hover:border-neutral-300 dark:hover:border-neutral-700 transition"
      >
        <span class="flex flex-col items-start gap-1">
          <span class="font-mono text-xs uppercase tracking-[0.18em] text-ink-subtle dark:text-neutral-400">
            impulsedinertia.substack.com
          </span>
          <span>Read the latest post &rarr;</span>
        </span>
      </a>
    </div>
  </div>
</section>
