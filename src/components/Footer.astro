  <div class="mx-auto max-w-content px-6 py-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
    <p class="text-sm text-ink-subtle dark:text-neutral-500">
      &copy; {year} Sridevi Vijayaraghavan
    </p>
    <p class="font-mono text-xs uppercase tracking-[0.14em] text-ink-subtle dark:text-neutral-500">
      Built with Astro &amp; a lot of Claude
    </p>
  </div>
</footer>
