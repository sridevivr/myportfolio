---
import type { Project } from '~/data/projects';

type Props = { project: Project };
const { project } = Astro.props;

// Category pill styling — each category gets a distinct color.
const categoryClasses: Record<Project['category'], string> = {
  business: 'bg-blue-100 text-blue-700 dark:bg-blue-950/60 dark:text-blue-300',
  personal: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-950/60 dark:text-emerald-300',
  fun:      'bg-amber-100 text-amber-700 dark:bg-amber-950/60 dark:text-amber-300',
  learning: 'bg-purple-100 text-purple-700 dark:bg-purple-950/60 dark:text-purple-300',
};

const categoryLabel: Record<Project['category'], string> = {
  business: 'Business',
  personal: 'Personal',
  fun:      'Fun',
  learning: 'Learning',
};
---

<article
  class="group flex flex-col overflow-hidden rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 transition hover:border-neutral-300 dark:hover:border-neutral-700 hover:shadow-md"
>
  {project.liveUrl ? (
    <a
      href={project.liveUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Open ${project.title} live`}
      class="block aspect-[16/10] overflow-hidden bg-neutral-100 dark:bg-neutral-950"
    >
      <img
        src={project.screenshot}
        alt={`${project.title} screenshot`}
        class="w-full h-full object-cover transition duration-300 group-hover:scale-[1.02]"
        loading="lazy"
      />
    </a>
  ) : (
    <div class="block aspect-[16/10] overflow-hidden bg-neutral-100 dark:bg-neutral-950">
      <img
        src={project.screenshot}
        alt={`${project.title} screenshot`}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  )}

  <div class="flex flex-col flex-1 p-6">
    <div class="flex items-start justify-between gap-3">
      <h3 class="text-lg md:text-xl font-semibold leading-snug text-ink dark:text-neutral-100">
        {project.title}
      </h3>
      <span class={`shrink-0 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${categoryClasses[project.category]}`}>
        {categoryLabel[project.category]}
      </span>
    </div>

    <p class="mt-3 text-[0.95rem] leading-relaxed text-ink-muted dark:text-neutral-300">
      {project.description}
    </p>

    <div class="mt-5 flex flex-wrap gap-4 text-sm pt-4 border-t border-neutral-100 dark:border-neutral-800">
      {project.liveUrl ? (
        <a
          href={project.liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 font-medium text-accent hover:text-accent-hover dark:text-indigo-400 dark:hover:text-indigo-300 transition"
        >
          Try it live
          <span aria-hidden="true">&rarr;</span>
        </a>
      ) : (
        <span class="font-medium text-ink-subtle dark:text-neutral-500">
          Live demo coming soon
        </span>
      )}
      <a
        href={project.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 font-medium text-ink-muted dark:text-neutral-400 hover:text-ink dark:hover:text-neutral-100 transition"
      >
        Source
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</article>
